modules = ["nodejs-20", "postgresql-16", "python-3.11"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Server"

[[workflows.workflow]]
name = "Run Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd polytrack-052 && node server.js"
waitForPort = 3000

[[ports]]
localPort = 3000
externalPort = 3000

[deployment]
run = ["sh", "-c", "cd polytrack-052 && node server.js"]
deploymentTarget = "cloudrun"
